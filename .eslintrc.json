{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
        "indent": [
            "error",
            "tab"
        ],
        "quotes": [
            "error",
            "double"
        ],
        "semi": [
            "error",
            "always"
        ],
		"max-params":
		[
			"error",
			{
				"max": 4
			}
		],
		"no-mixed-spaces-and-tabs": [
			"error",
			"smart-tabs"
		],
		"max-depth": [
			"error",
			{
				"max": 3
			}
		],
		"max-len": [
			"error",
			{
				"code": 120,
				"tabWidth": 4,
				"ignoreUrls": true,
				"ignorePattern": "^import\\s.+\\sfrom\\s.+;$",
				"ignoreString": true
			}
		],
		"max-statements-per-line": [
			"error",
			{
				"max": 1
			}
		],
		"no-multi-spaces": [
			"error",
			{
				"ignoreEOLComments": true
			}
		],
		"no-multiple-empty-lines": [
			"error",
			{
				"max": 1,
				"maxEOF": 1
			}
		],
		"spaced-comment": [
			"error",
			"always"
		],
		"line-comment-position": [
			"error",
			{
				"position": "above"
			}
		],
		"no-inline-comments": "error",
		"no-trailing-spaces": [
			"error",
			{
				"ignoreComments": true
			}
		]
    }
}
