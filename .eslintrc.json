{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
        "indent": [
            "error",
            "tab"
        ],
        "quotes": [
            "error",
            "double"
        ],
        "semi": [
            "error",
            "always"
        ],
		"max-params":
		[
			"error",
			{
				"max": 4
			}
		],
		"no-mixed-spaces-and-tabs": [
			"error",
			"smart-tabs"
		],
		"max-depth": [
			"error",
			{
				"max": 3
			}
		],
		"max-len": [
			"error",
			{
				"code": 100,
				"tabWidth": 4,
				"ignoreUrls": true,
				"ignorePattern": "^import\\s.+\\sfrom\\s.+;$"
			}
		]
    }
}
